# General
TOKENIZERS_PARALLELISM=false
PYTHONWARNINGS=default

# Hugging Face
HUGGINGFACE_HUB_TOKEN=your_huggingface_token_here
HF_HOME=/path/to/your/storage/hf_cache
TRANSFORMERS_CACHE=/path/to/your/storage/hf_cache

# Python / Pip / temp storage
PIP_CACHE_DIR=/path/to/your/storage/pip_cache
TMPDIR=/path/to/your/storage/tmp

# Weights & Biases
WANDB_API_KEY=your_wandb_api_key_here
WANDB_PROJECT=deepfake_robustness
WANDB_ENTITY=your_wandb_entity_here
WANDB_MODE=offline

# Optional dataset path placeholders
PUBMED_REAL_PATH=data/raw/pubmed_abstracts/pubmed_real.csv
FAKE_DATA_PATH=data/raw/med_mmhl
